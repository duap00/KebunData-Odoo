<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_kebun_iot_sensor_tree" model="ir.ui.view">
        <field name="name">kebun.iot.sensor.tree</field>
        <field name="model">kebun.iot.sensor</field>
        <field name="arch" type="xml">
            <list string="Water Quality Readings">
                <field name="name"/>
                <field name="device_id"/>
                <field name="ph"/>
                <field name="tds"/>
                <field name="ec"/>
                <field name="temperature"/>
                <field name="last_sync"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_kebun_iot_sensor_form" model="ir.ui.view">
        <field name="name">kebun.iot.sensor.form</field>
        <field name="model">kebun.iot.sensor</field>
        <field name="arch" type="xml">
            <form string="Water Quality Monitor">
                <header>
                    <button name="action_fetch_tuya_data" string="Sync from Tuya" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="device_id"/>
                        </group>
                        <group>
                            <field name="last_sync"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Water Metrics">
                            <group col="2">
                                <field name="ph"/>
                                <field name="tds"/>
                                <field name="ec"/>
                                <field name="sg"/>
                                <field name="salinity"/>
                                <field name="temperature"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action & Menu -->
    <record id="action_kebun_iot_sensor" model="ir.actions.act_window">
        <field name="name">Water Monitors</field>
        <field name="res_model">kebun.iot.sensor</field>
        <field name="view_mode">list,form,graph</field>
    </record>

    <menuitem id="menu_kebun_root" name="KebunData IoT"/>
    <menuitem id="menu_kebun_sensor" name="Water Monitors" parent="menu_kebun_root" action="action_kebun_iot_sensor"/>
</odoo>
